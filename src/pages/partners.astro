---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import PullQuote from '../components/PullQuote.astro';
import { partners, friends, testimonial } from '../content/partners';
---
<Base title="Partners" description="Organizations and individuals supporting the American Institute for Michaels.">
  <Masthead
    eyebrow="Partners"
    title="Diversifying society, one given name at a time."
    lede="AIM collaborates with organizations and individuals who share our mission to broaden the institutional surface area of community by given name."
  />

  <section class="container section">
    <SectionEyebrow index="I" label="Partner Organizations" />
    <ul class="partners">
      {partners.map((p) => (
        <li class="partner">
          <img class="partner__mark" src={p.logo.src} alt={`${p.org} logo`} />
          <h3 class="partner__org">{p.org}</h3>
          <p class="partner__person">{p.person}</p>
          <p class="partner__role">{p.role}</p>
        </li>
      ))}
    </ul>
  </section>

  <hr class="rule container" />

  <section class="container section">
    <SectionEyebrow index="II" label="Friends of Michaels" />
    <p class="prose">
      We are also grateful for the individual supporters whose advocacy makes the Institute's work possible:
    </p>
    <p class="friends">{friends.join(' · ')}</p>
  </section>

  <hr class="rule container" />

  <section class="container section">
    <SectionEyebrow index="III" label="In Their Words" />
    <PullQuote quote={testimonial.quote} attribution={testimonial.attribution} role={testimonial.role} />
  </section>
</Base>

<style>
  .section { padding-block: var(--s-6); }
  .partners {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: var(--s-7);
  }
  .partner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-3);
    padding: var(--s-6);
    border: 1px solid var(--rule);
    background: color-mix(in oklab, var(--parchment) 96%, var(--brand-olive));
  }
  .partner__mark {
    display: block;
    width: auto;
    height: 6rem;
    max-width: 100%;
    object-fit: contain;
    object-position: left center;
    margin-bottom: var(--s-3);
  }
  .partner__org {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.375rem;
    color: var(--ink-navy);
    margin: 0;
    line-height: 1.2;
  }
  .partner__person {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--fg);
    margin: 0;
  }
  .partner__role {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand-olive);
    margin: 0;
  }
  .friends {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--brand-olive);
    font-size: 1.125rem;
  }
</style>
