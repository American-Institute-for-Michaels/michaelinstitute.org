---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
---
<Base title="Not Found" description="The requested page could not be located.">
  <Masthead
    eyebrow="Error 404 · Page Not Found"
    title="This Michael could not be located."
    lede="The Institute regrets that the page you have requested is not part of our archive. Possibilities include: a transcription error in the URL; a page since withdrawn under Article IX; or the work of an unauthorized link."
  />

  <section class="container section">
    <div class="prose">
      <SectionEyebrow index="I" label="Recommended Next Steps" />
      <ol class="steps">
        <li>Consult the index of <a href="/notable-michaels">Notable Michaels</a> to confirm the spelling of the entry sought.</li>
        <li>Return to <a href="/">the front matter</a> and approach by the principal navigation.</li>
        <li>If you are confident the page existed, write to <a href="mailto:hello@michaelinstitute.org">the general office</a>; the Recording Secretary maintains a list of withdrawn pages and may be able to assist.</li>
      </ol>
    </div>
  </section>

  <hr class="rule container" />

  <section class="container section">
    <div class="prose">
      <p class="apology">
        The Institute extends its sincere apology for the inconvenience.
      </p>
    </div>
  </section>
</Base>

<style>
  .section { padding-block: var(--s-6); }
  .steps {
    padding-left: var(--s-5);
  }
  .steps li {
    margin-bottom: var(--s-3);
    font-family: var(--font-serif);
    line-height: 1.55;
  }
  .apology {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--brand-olive);
    font-size: 1.15rem;
    margin: 0;
  }
</style>
