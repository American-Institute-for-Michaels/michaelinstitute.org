---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { chapters } from '../content/chapters';

const regions = ['The Americas', 'Europe', 'Africa', 'Asia and Oceania'] as const;
const grouped = regions.map((r) => ({
  region: r,
  entries: chapters.filter((c) => c.region === r).sort((a, b) => a.city.localeCompare(b.city)),
}));
const total = chapters.length;
const countries = new Set(chapters.map((c) => c.country)).size;
const dormant = chapters.filter((c) => c.cadence === 'In abeyance').length;
---
<Base title="Chapters" description="The Institute's global chapter network: a directory of chartered chapters across more than eighty cities.">
  <Masthead
    eyebrow="Global Network"
    title="Chartered chapters."
    lede="The Institute maintains a network of chartered chapters in more than eighty cities across four continents. Each chapter is convened by a resident Michael of standing and follows a cadence of its own determination, subject to the standards published in Article VI of the bylaws."
  />

  <section class="container section">
    <SectionEyebrow index="I" label="At a glance" />
    <dl class="overview">
      <div><dt>Chartered chapters</dt><dd>{total}</dd></div>
      <div><dt>Countries with presence</dt><dd>{countries}</dd></div>
      <div><dt>Continents</dt><dd>4</dd></div>
      <div><dt>Chapters in abeyance</dt><dd>{dormant}</dd></div>
    </dl>
  </section>

  {grouped.map((g) => (
    <section class="container section">
      <SectionEyebrow label={g.region} />
      <ul class="chapter-list">
        {g.entries.map((c) => (
          <li class={`chapter ${c.cadence === 'In abeyance' ? 'chapter--dormant' : ''}`}>
            <p class="chapter__city">{c.city}<span class="chapter__country">, {c.country}</span></p>
            <p class="chapter__coord">{c.coordinator} · <em>coordinator</em></p>
            <p class="chapter__meta">
              <span>Chartered {c.chartered}</span>
              <span class="sep">·</span>
              <span>{c.cadence}</span>
            </p>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <hr class="rule container" />

  <section class="container section">
    <div class="prose">
      <SectionEyebrow label="Chartering a Chapter" />
      <p>
        Local chapters may be chartered upon written application by no fewer
        than three Michaels resident in a common locality. The application
        must include a statement of intended activities, a proposed cadence,
        and the name of a coordinator willing to serve a renewable two-year
        term. Inquiries may be directed to
        <a href="mailto:hello@michaelinstitute.org">the general office</a>.
      </p>
      <p class="footnote">
        Chapters listed as "in abeyance" are deemed inactive under Article
        VI, §2 of the bylaws. The Institute hopes to revive these chapters
        when conditions permit.
      </p>
    </div>
  </section>
</Base>

<style>
  .section { padding-block: var(--s-6); }
  .overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(14rem, 100%), 1fr));
    gap: 0;
    margin: 0 0 var(--s-6);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .overview > div {
    padding: var(--s-5);
    border-right: 1px solid var(--rule);
  }
  .overview > div:last-child { border-right: none; }
  .overview dt { font-family: var(--font-sans); font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand-olive); margin: 0 0 var(--s-2); }
  .overview dd { font-family: var(--font-serif); font-size: 2.5rem; font-weight: 600; color: var(--brand-orange); margin: 0; font-variant-numeric: tabular-nums; }
  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: var(--s-4) var(--s-6);
  }
  .chapter {
    padding: var(--s-4) 0;
    border-top: 1px solid var(--rule);
  }
  .chapter--dormant { opacity: 0.55; }
  .chapter__city {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink-navy);
    margin: 0 0 var(--s-1);
  }
  .chapter__country { font-weight: 400; color: var(--muted); }
  .chapter__coord {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    margin: 0 0 var(--s-2);
    color: var(--ink-navy);
  }
  .chapter__meta {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand-olive);
    margin: 0;
  }
  .sep { opacity: 0.5; padding: 0 var(--s-2); }
  .footnote { font-size: 0.9rem; font-style: italic; color: var(--muted); }
</style>
