---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  role: string;
  bio: string;
  portrait: ImageMetadata;
}
const { name, role, bio, portrait } = Astro.props;
---
<article class="card">
  <Image src={portrait} alt={`Portrait of ${name}`} width={240} height={240} class="card__portrait" />
  <div class="card__body">
    <h3 class="card__name">{name}</h3>
    <p class="card__role">{role}</p>
    <p class="card__bio">{bio}</p>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--s-5);
    padding-block: var(--s-5);
    border-top: 1px solid var(--rule);
  }
  .card:last-child { border-bottom: 1px solid var(--rule); }
  .card__portrait {
    width: 6rem;
    height: 6rem;
    border-radius: 999px;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }
  .card__body { min-width: 0; }
  .card__name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 var(--s-1);
    color: var(--ink-navy);
  }
  .card__role {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--brand-olive);
    margin: 0 0 var(--s-3);
  }
  .card__bio { margin: 0; max-width: 60ch; }
  @media (max-width: 30rem) {
    .card { grid-template-columns: 1fr; }
    .card__portrait { width: 5rem; height: 5rem; }
  }
</style>
