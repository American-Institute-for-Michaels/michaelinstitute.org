---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---
<figure class="band">
  <Image src={src} alt={alt} widths={[800, 1200, 1600, 2000]} sizes="100vw" class="band__img" />
  {caption && <figcaption class="band__caption">{caption}</figcaption>}
</figure>

<style>
  .band {
    margin: var(--s-8) 0;
    padding: 0;
  }
  .band__img {
    width: 100%;
    height: clamp(18rem, 32vw, 28rem);
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
    display: block;
  }
  .band__caption {
    max-width: var(--container);
    margin: var(--s-3) auto 0;
    padding-inline: var(--gutter);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--brand-olive);
    font-style: italic;
  }
</style>
