---
import { site, footerColumns } from '../content/site';
const year = new Date().getFullYear();
const range = year > site.copyrightStart ? `${site.copyrightStart}–${year}` : `${site.copyrightStart}`;
---
<footer class="footer">
  <div class="container">
    <div class="footer__cols">
      {footerColumns.map((col) => (
        <div class="col">
          <p class="col__heading">{col.heading}</p>
          <ul class="col__links">
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <hr class="footer__rule" />
    <div class="footer__inner">
      <p class="colophon">
        Set in Source Serif 4 &amp; Inter. Hand-built with Astro &amp; TypeScript. Hosted on GitHub Pages.
      </p>
      <ul class="footer__meta">
        <li><a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></li>
        <li><a href={site.twitter.url} rel="noopener">{site.twitter.handle}</a></li>
        <li>© {range} {site.short}</li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-navy);
    color: color-mix(in oklab, var(--parchment) 88%, transparent);
    margin-top: var(--s-9);
    padding-block: var(--s-7);
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(14rem, 100%), 1fr));
    gap: var(--s-6);
    margin-bottom: var(--s-6);
  }
  .col__heading {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-orange);
    margin: 0 0 var(--s-4);
    font-weight: 600;
  }
  .col__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .col__links a {
    color: var(--parchment);
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    border-bottom: 1px solid transparent;
  }
  .col__links a:hover { border-bottom-color: var(--brand-orange); }
  .footer__rule {
    border: none;
    border-top: 1px solid color-mix(in oklab, var(--parchment) 20%, transparent);
    margin: var(--s-5) 0;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--s-5);
  }
  .colophon { margin: 0; max-width: 36rem; opacity: 0.78; font-style: italic; }
  .footer__meta {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }
  .footer a { color: var(--parchment); text-decoration: none; border-bottom: 1px solid transparent; }
  .footer__meta a:hover { border-bottom-color: var(--brand-orange); }
</style>
