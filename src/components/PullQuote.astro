---
interface Props {
  quote: string;
  attribution: string;
  role?: string;
}
const { quote, attribution, role } = Astro.props;
---
<figure class="pq">
  <blockquote class="pq__quote">
    <p>&ldquo;{quote}&rdquo;</p>
  </blockquote>
  <figcaption class="pq__cite">
    <span class="pq__name">{attribution}</span>
    {role && <span class="pq__role">{role}</span>}
  </figcaption>
</figure>

<style>
  .pq {
    margin: var(--s-7) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding-block: var(--s-6);
  }
  .pq__quote p {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    line-height: 1.3;
    font-style: italic;
    color: var(--ink-navy);
    margin: 0;
  }
  .pq__cite {
    margin-top: var(--s-5);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--brand-olive);
    display: flex;
    flex-direction: column;
    gap: var(--s-1);
  }
  .pq__name {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }
  .pq__role { font-style: italic; }
</style>
